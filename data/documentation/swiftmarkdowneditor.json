{"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"topicSections":[{"title":"エディタビュー","identifiers":["doc:\/\/SwiftMarkdownEditor\/documentation\/SwiftMarkdownEditor\/MarkdownEditor","doc:\/\/SwiftMarkdownEditor\/documentation\/SwiftMarkdownEditor\/MarkdownEditorMode"],"anchor":"エディタビュー"},{"generated":true,"title":"Extended Modules","identifiers":["doc:\/\/SwiftMarkdownEditor\/documentation\/SwiftMarkdownEditor\/SwiftMarkdownEditorTextKit"],"anchor":"Extended-Modules"}],"variants":[{"paths":["\/documentation\/swiftmarkdowneditor"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/SwiftMarkdownEditor\/documentation\/SwiftMarkdownEditor","interfaceLanguage":"swift"},"hierarchy":{"paths":[[]]},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"codeVoice","code":"SwiftMarkdownEditor"},{"type":"text","text":" は "},{"type":"codeVoice","code":"MarkdownEditor"},{"type":"text","text":" を提供する。TextKit 2 テキストビューをラップしてソース編集を行い、レンダリングプレビューには "},{"type":"codeVoice","code":"MarkdownView"},{"type":"text","text":" を再利用するドロップイン SwiftUI "},{"type":"codeVoice","code":"View"},{"type":"text","text":"。バインドされたプレーン Markdown 文字列が唯一の正であり、中間表現は公開しない。"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"MarkdownEditorMode"},{"type":"text","text":" で制御する 3 つの表示モードをサポートする。"},{"type":"codeVoice","code":".edit"},{"type":"text","text":" モードでは TextKit 2 レイアウトマネージャがライブシンタックスハイライトを適用してソースを表示する。"},{"type":"codeVoice","code":".preview"},{"type":"text","text":" モードではレンダリングされた "},{"type":"codeVoice","code":"MarkdownView"},{"type":"text","text":" がコンテンツ領域を占める。"},{"type":"codeVoice","code":".split"},{"type":"text","text":" モード（macOS や幅広 iPad レイアウトに最適）では両パネルがディバイダーで区切られて並列表示される。ユーザーはエディタヘッダーのセグメントコントロールでモードを切り替える。"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":".edit"},{"type":"text","text":" モードと "},{"type":"codeVoice","code":".split"},{"type":"text","text":" モードでは、モードスイッチャーの下にスクロール可能なフォーマットツールバーが表示される。各ボタンは太字・斜体・取り消し線・インラインコード・見出し変換・箇条書き・引用・リンク挿入などのフォーマット変換をソーステキストビューの選択範囲に適用する。"}],"type":"paragraph"},{"inlineContent":[{"text":"オートフォーマット入力ルールはユーザーのタイプに応じて自動的に発火する。デフォルトのルールセットは Return でリストアイテムを継続し、選択テキストを対応する Markdown デリミタで囲む。ルールを拡張・置換するにはカスタムの ","type":"text"},{"code":"InputRuleProcessor","type":"codeVoice"},{"text":" をイニシャライザに渡す。","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import SwiftUI","import SwiftMarkdownEditor","","struct NoteEditor: View {","    @State private var source = \"# My Note\\n\\nStart writing…\"","","    var body: some View {","        MarkdownEditor(text: $source)","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"色とスペーシングは SwiftUI 環境内の ","type":"text"},{"code":"swift-design-system","type":"codeVoice"},{"text":" テーマから取得するため、アプリ全体のデザインに自動的に合わせる。","type":"text"}],"type":"paragraph"}]}],"metadata":{"title":"SwiftMarkdownEditor","modules":[{"name":"SwiftMarkdownEditor"}],"roleHeading":"Framework","color":{"standardColorIdentifier":"orange"},"externalID":"SwiftMarkdownEditor","symbolKind":"module","role":"collection"},"abstract":[{"type":"text","text":"ライブシンタックスハイライト・フォーマットツールバー・レンダリングプレビューを備えた SwiftUI Markdown エディタ。"}],"kind":"symbol","references":{"doc://SwiftMarkdownEditor/documentation/SwiftMarkdownEditor":{"role":"collection","url":"\/documentation\/swiftmarkdowneditor","type":"topic","abstract":[{"text":"ライブシンタックスハイライト・フォーマットツールバー・レンダリングプレビューを備えた SwiftUI Markdown エディタ。","type":"text"}],"kind":"symbol","identifier":"doc:\/\/SwiftMarkdownEditor\/documentation\/SwiftMarkdownEditor","title":"SwiftMarkdownEditor"},"doc://SwiftMarkdownEditor/documentation/SwiftMarkdownEditor/MarkdownEditor":{"role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MarkdownEditor"}],"url":"\/documentation\/swiftmarkdowneditor\/markdowneditor","abstract":[{"text":"ライブシンタックスハイライト・フォーマットツールバー・レンダリングプレビューを備えた SwiftUI Markdown エディタ。","type":"text"}],"fragme