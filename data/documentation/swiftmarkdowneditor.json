{"topicSections":[{"title":"Editor View","identifiers":["doc:\/\/SwiftMarkdownEditor\/documentation\/SwiftMarkdownEditor\/MarkdownEditor","doc:\/\/SwiftMarkdownEditor\/documentation\/SwiftMarkdownEditor\/MarkdownEditorMode"],"anchor":"Editor-View"},{"title":"Extended Modules","identifiers":["doc:\/\/SwiftMarkdownEditor\/documentation\/SwiftMarkdownEditor\/SwiftMarkdownEditorTextKit"],"generated":true,"anchor":"Extended-Modules"}],"abstract":[{"text":"A SwiftUI Markdown editor with live syntax highlighting, a formatting toolbar, and an optional rendered preview.","type":"text"}],"kind":"symbol","identifier":{"url":"doc:\/\/SwiftMarkdownEditor\/documentation\/SwiftMarkdownEditor","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/swiftmarkdowneditor"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"inlineContent":[{"code":"SwiftMarkdownEditor","type":"codeVoice"},{"type":"text","text":" provides "},{"code":"MarkdownEditor","type":"codeVoice"},{"type":"text","text":", a drop-in SwiftUI "},{"code":"View","type":"codeVoice"},{"type":"text","text":" that wraps a TextKit 2 text view for source editing and reuses "},{"code":"MarkdownView","type":"codeVoice"},{"type":"text","text":" for the rendered preview. The plain Markdown string bound to the view is always the single source of truth — no intermediate representation is exposed."}],"type":"paragraph"},{"inlineContent":[{"text":"The editor supports three presentation modes controlled by ","type":"text"},{"code":"MarkdownEditorMode","type":"codeVoice"},{"text":". In ","type":"text"},{"code":".edit","type":"codeVoice"},{"text":" mode the source is shown with live syntax highlighting applied by the underlying TextKit 2 layout manager. In ","type":"text"},{"code":".preview","type":"codeVoice"},{"text":" mode the rendered ","type":"text"},{"code":"MarkdownView","type":"codeVoice"},{"text":" fills the content area. In ","type":"text"},{"code":".split","type":"codeVoice"},{"text":" mode — best on macOS and wide iPad layouts — both panels appear side by side, separated by a divider. The user switches between modes using a segmented control in the editor header.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A scrollable formatting toolbar sits below the mode switcher in "},{"code":".edit","type":"codeVoice"},{"type":"text","text":" and "},{"code":".split","type":"codeVoice"},{"type":"text","text":" modes. Each button applies a formatting transform — bold, italic, strikethrough, inline code, heading promotion, bullet list, blockquote, and link insertion — to the selected range in the source text view."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Autoformatting input rules fire automatically as the user types. The default rule set continues list items on return and wraps selected text in paired Markdown delimiters. Pass a custom "},{"type":"codeVoice","code":"InputRuleProcessor"},{"type":"text","text":" to the initialiser to extend or replace the rules."}],"type":"paragraph"},{"code":["import SwiftUI","import SwiftMarkdownEditor","","struct NoteEditor: View {","    @State private var source = \"# My Note\\n\\nStart writing…\"","","    var body: some View {","        MarkdownEditor(text: $source)","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Colors and spacing come from the ","type":"text"},{"code":"swift-design-system","type":"codeVoice"},{"text":" theme in the SwiftUI environment, so the editor matches the rest of your app automatically.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[[]]},"metadata":{"role":"collection","modules":[{"name":"SwiftMarkdownEditor"}],"symbolKind":"module","roleHeading":"Framework","color":{"standardColorIdentifier":"orange"},"externalID":"SwiftMarkdownEditor","title":"SwiftMarkdownEditor"},"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://SwiftMarkdownEditor/documentation/SwiftMarkdownEditor/SwiftMarkdownEditorTextKit":{"abstract":[],"role":"collection","identifier":"doc:\/\/SwiftMarkdownEditor\/documentation\/SwiftMarkdownEditor\/SwiftMarkdownEditorTextKit","title":"SwiftMarkdownEditorTextKit","url":"\/documentation\/swiftmarkdowneditor\/swiftmarkdowneditortextkit","kind":"symbol","type":"topic"},"doc://SwiftMarkdownEditor/documentation/SwiftMarkdownEditor/MarkdownEditor":{"identifier":"doc:\/\/SwiftMarkdownEditor\/documentation\/SwiftMarkdownEditor\/MarkdownEditor","navigatorTitle":[{"text":"MarkdownEditor","kind":"identifier"}],"title":"MarkdownEditor","kind":"symbol","abstract":[{"text":"A SwiftUI Markdown editor with live syntax highlighting, a formatting","type":"text"},{"text":" ","type":"text"},{"text":"toolbar, and an optional rendered preview.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MarkdownEditor","kind":"identifier"}],"url":"\/documentation\/swiftmarkdowneditor\/markdowneditor","type":"topic","role":"symbol"},"doc://SwiftMarkdownEditor/documentation/SwiftMarkdownEditor/MarkdownEditorMode":{"kind":"symbol","identifier":"doc:\/\/SwiftMarkdownEditor\/documentation\/SwiftMarkdownEditor\/MarkdownEditorMode","type":"topic","abstract":[{"type":"text","text":"How the editor presents content."}],"title":"MarkdownEditorMode","url":"\/documentation\/swiftmarkdowneditor\/markdowneditormode","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"MarkdownEditorMode"}],"navigatorTitle":[{"kind":"identifier","text":"MarkdownEditorMode"}],"role":"symbol"},"doc://SwiftMarkdownEditor/documentation/SwiftMarkdownEditor":{"type":"topic","identifier":"doc:\/\/SwiftMarkdownEditor\/documentation\/SwiftMarkdownEditor","abstract":[{"text":"A SwiftUI Markdown editor with live syntax highlighting, a formatting toolbar, and an optional rendered preview.","type":"text"}],"t