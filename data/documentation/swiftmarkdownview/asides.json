: return .orange","        default: return DefaultAsideStyle().accentColor(for: kind, colorPalette: colorPalette)","        }","    }","","    func backgroundColor(for kind: AsideKind, colorPalette: any ColorPalette) -> Color {","        accentColor(for: kind, colorPalette: colorPalette).opacity(0.15)","    }","","    func titleColor(for kind: AsideKind, colorPalette: any ColorPalette) -> Color {","        accentColor(for: kind, colorPalette: colorPalette)","    }","}"],"type":"codeListing"},{"anchor":"%E3%82%B9%E3%82%BF%E3%82%A4%E3%83%AB%E3%81%AE%E9%81%A9%E7%94%A8","level":3,"type":"heading","text":"スタイルの適用"},{"syntax":"swift","code":["MarkdownView(source)","    .asideStyle(MyAsideStyle())"],"type":"codeListing"},{"anchor":"%E3%83%87%E3%83%95%E3%82%A9%E3%83%AB%E3%83%88%E3%82%B9%E3%82%BF%E3%82%A4%E3%83%AB","level":2,"type":"heading","text":"デフォルトスタイル"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftMarkdownView\/documentation\/SwiftMarkdownView\/DefaultAsideStyle"},{"type":"text","text":"は以下の特徴を持ちます："}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"アイコン","type":"text"}]},{"text":": SF Symbolsを使用した直感的なアイコン","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"アクセントカラー","type":"text"}],"type":"strong"},{"type":"text","text":": 種類に応じたセマンティックカラー"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Note: 青系"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Warning: オレンジ\/赤系","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Tip: 緑系"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bug: 赤系"}]}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"背景色"}]},{"text":": アクセントカラーの薄い透明版","type":"text"}]}]},{"conte