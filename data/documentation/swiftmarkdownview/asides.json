ype":"text","text":"定義済みキーワード以外は"},{"type":"codeVoice","code":"custom"},{"type":"text","text":"として扱われます："}],"type":"paragraph"},{"code":["MarkdownView(\"\"\"","> MyCustomNote: 独自のコールアウトです。","\"\"\")"],"type":"codeListing","syntax":"swift"},{"text":"カスタムスタイル","level":2,"anchor":"%E3%82%AB%E3%82%B9%E3%82%BF%E3%83%A0%E3%82%B9%E3%82%BF%E3%82%A4%E3%83%AB","type":"heading"},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftMarkdownView\/documentation\/SwiftMarkdownView\/AsideStyle"},{"type":"text","text":"プロトコルに準拠したスタイルを作成することで、"},{"type":"text","text":" "},{"type":"text","text":"Asideの見た目をカスタマイズできます。"}],"type":"paragraph"},{"text":"AsideStyleプロトコル","level":3,"anchor":"AsideStyle%E3%83%97%E3%83%AD%E3%83%88%E3%82%B3%E3%83%AB","type":"heading"},{"code":["public protocol AsideStyle: Sendable {","    func icon(for kind: AsideKind) -> String","    func accentColor(for kind: AsideKind, colorPalette: any ColorPalette) -> Color","    func backgroundColor(for kind: AsideKind, colorPalette: any ColorPalette) -> Color","    func titleColor(for kind: AsideKind, colorPalette: any ColorPalette) -> Color","}"],"type":"codeListing","syntax":"swift"},{"text":"カスタムスタイルの例","level":3,"anchor":"%E3%82%AB%E3%82%B9%E3%82%BF%E3%83%A0%E3%82%B9%E3%82%BF%E3%82%A4%E3%83%AB%E3%81%AE%E4%BE%8B","type":"heading"},{"code":["struct MyAsideStyle: AsideStyle {","    func icon(for kind: AsideKind) -> String {","        switch kind {","        case .warning: return \"flame.fill\"","        case .tip: return \"lightbulb.fill\"","        case .bug: return \"ant.fill\"","        default: return DefaultAsideStyle().icon(for: kind)","        }","    }","","    func accentColor(for kind: AsideKind, colorPalette: any ColorPalette) -> Color {","        switch kind {","        case .tip: return .mint","        case .warning: return .orange","        default: return DefaultAsideStyle().accentColor(for: kind, colorPalette: colorPalette)","        }","    }","","    func backgroundColor(for kind: AsideKind, colorPalette: any ColorPalette) -> Color {","        accentColor(for: kind, colorPalette: colorPalette).opacity(0.15)","    }","","    func titleColor(for kind: AsideKind, colorPalette: any ColorPalette) -> Color {","        accentColor(for: kind, colorPalette: colorPalette)","    }","}"],"type":"codeListing","syntax":"swift"},{"text":"スタイルの適用","level":3,"anchor":"%E3%82%B9%E3%82%BF%E3%82%A4%E3%83%AB%E3%81%AE%E9%81%A9%E7%94%A8","type":"heading"},{"code":["MarkdownView(source)","    .asideStyle(MyAsideStyle())"],"type":"codeListing","syntax":"swift"},{"text":"デフォルトスタイル","level":2,"anchor":"%E3%83%87%E3%83%95%E3%82%A9%E3%83%AB%E3%83%88%E3%82%B9%E3%82%BF%E3%82%A4%E3%83%AB","type":"heading"},{"inlineContent":[{"identifier":"doc:\/\/SwiftMarkdownView\/documentation\/SwiftMarkdownView\/DefaultAsideStyle","type":"reference","isActive":true},{"type":"text","text":"は以下の特徴を持ちます："}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"アイコン"}]},{"text":": SF Symbolsを使用した直感的なアイコン","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"アクセントカラー"}],"type":"strong"},{"text":": 種類に応じたセマンティックカラー","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Note: 青系","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Warning: オレンジ\/赤系","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Tip: 緑系"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Bug: 赤系","type":"text"}]}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"背景色"}],"type":"strong"},{"text":": アクセントカラーの薄い透明版","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"左ボーダー","type":"text"}],"type":"strong"},{"text":": アクセントカラーで強調","type":"text"}],"type":"paragraph"}]}],"type":"unorderedLis