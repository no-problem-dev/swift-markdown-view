{"abstract":[{"text":"Learn the basics of rendering Markdown with ","type":"text"},{"code":"SwiftMarkdownView","type":"codeVoice"},{"text":".","type":"text"}],"kind":"article","primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"code":"SwiftMarkdownView","type":"codeVoice"},{"type":"text","text":" lets you drop Markdown rendering into any SwiftUI app with a single import. The library parses CommonMark and GitHub Flavored Markdown and renders it as native SwiftUI — headings, code blocks, tables, task lists, asides, images, and more — while automatically picking up your "},{"code":"swift-design-system","type":"codeVoice"},{"type":"text","text":" theme."}]},{"anchor":"Installation","level":2,"text":"Installation","type":"heading"},{"anchor":"Swift-Package-Manager","level":3,"text":"Swift Package Manager","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the dependency to your "},{"type":"codeVoice","code":"Package.swift"},{"type":"text","text":":"}]},{"code":["dependencies: [","    .package(","        url: \"https:\/\/github.com\/no-problem-dev\/swift-markdown-view.git\",","        .upToNextMajor(from: \"1.4.0\")","    )","]"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then add the product to your target:"}]},{"code":[".target(","    name: \"YourTarget\",","    dependencies: [","        .product(name: \"SwiftMarkdownView\", package: \"swift-markdown-view\")","    ]",")"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To enable syntax highlighting, also add "},{"code":"SwiftMarkdownViewHighlightJS","type":"codeVoice"},{"type":"text","text":":"}]},{"code":[".product(name: \"SwiftMarkdownViewHighlightJS\", package: \"swift-markdown-view\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Basic-Usage","level":2,"text":"Basic Usage","type":"heading"},{"text":"Rendering a string","level":3,"anchor":"Rendering-a-string","type":"heading"},{"inlineContent":[{"text":"Pass a Markdown string directly to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftMarkdownView\/documentation\/SwiftMarkdownView\/MarkdownView"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import SwiftUI","import SwiftMarkdownView","","struct ContentView: View {","    var body: some View {","        ScrollView {","            MarkdownView(\"\"\"","            # Hello, Markdown!","","            This is **bold**, *italic*, and `inline code`.","","            ## Lists","","            - Item one","            - Item two","            - [x] Completed task","","            ```swift","            let message = \"Hello, World!\"","            print(message)","            ```","            \"\"\")","            .padding()","        }","    }","}"],"type":"codeListing"},{"text":"Pre-parsing for performance","level":3,"anchor":"Pre-parsing-for-performance","type":"heading"},{"inlineContent":[{"text":"When you display the same Markdown in multiple places — or parse it off the main thread — use ","type":"text"},{"code":"MarkdownContent","type":"codeVoice"},{"text":" directly:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let content = MarkdownContent(parsing: longMarkdownString)","","\/\/ Later, on the main thread:","MarkdownView(content)"],"type":"codeListing"},{"text":"Applying styles","level":3,"anchor":"Applying-styles","type":"heading"},{"inlineContent":[{"text":"Use environment modifiers to control how elements appear:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["MarkdownView(source)","    .codeBlockStyle(TerminalCodeBlockStyle())","    .headingStyle(ColoredHeadingStyle())","    .markdownLinkStyle(ClassicLinkStyle())","    .markdownTableStyle(StripedTableStyle())"],"type":"codeListing"},{"text":"Enabling syntax highlighting","level":3,"anchor":"Enabling