{"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SwiftMarkdownView"},{"text":" lets you drop Markdown rendering into any SwiftUI app with a single import. The library parses CommonMark and GitHub Flavored Markdown and renders it as native SwiftUI — headings, code blocks, tables, task lists, asides, images, and more — while automatically picking up your ","type":"text"},{"type":"codeVoice","code":"swift-design-system"},{"text":" theme.","type":"text"}]},{"anchor":"Installation","type":"heading","text":"Installation","level":2},{"anchor":"Swift-Package-Manager","type":"heading","text":"Swift Package Manager","level":3},{"type":"paragraph","inlineContent":[{"text":"Add the dependency to your ","type":"text"},{"type":"codeVoice","code":"Package.swift"},{"text":":","type":"text"}]},{"type":"codeListing","code":["dependencies: [","    .package(","        url: \"https:\/\/github.com\/no-problem-dev\/swift-markdown-view.git\",","        .upToNextMajor(from: \"1.4.0\")","    )","]"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then add the product to your target:"}]},{"type":"codeListing","code":[".target(","    name: \"YourTarget\",","    dependencies: [","        .product(name: \"SwiftMarkdownView\", package: \"swift-markdown-view\")","    ]",")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To enable syntax highlighting, also add "},{"type":"codeVoice","code":"SwiftMarkdownViewHighlightJS"},{"type":"text","text":":"}]},{"type":"codeListing","code":[".product(name: \"SwiftMarkdownViewHighlightJS\", package: \"swift-markdown-view\")"],"syntax":"swift"},{"anchor":"Basic-Usage","type":"heading","text":"Basic Usage","level":2},{"anchor":"Rendering-a-string","type":"heading","text":"Rendering a string","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pass a Markdown strin