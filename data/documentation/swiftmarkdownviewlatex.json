{"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"code":"SwiftMarkdownViewLaTeX","type":"codeVoice"},{"text":" is an optional add-on for ","type":"text"},{"code":"SwiftMarkdownView","type":"codeVoice"},{"text":" that upgrades math expressions from plain source display to proper LaTeX typesetting. It provides ","type":"text"},{"code":"LaTeXMathRenderer","type":"codeVoice"},{"text":", a ","type":"text"},{"code":"MathRenderer","type":"codeVoice"},{"text":" implementation that delegates rendering to SwiftLaTeXView — a lightweight wrapper around the SwiftMath engine that renders LaTeX directly into Core Text glyphs without a WebView.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Both inline math (","type":"text"},{"type":"codeVoice","code":"$...$"},{"text":") and display math (","type":"text"},{"type":"codeVoice","code":"$$...$$"},{"text":") in Markdown source are supported. Inline expressions flow inside the surrounding ","type":"text"},{"type":"codeVoice","code":"Text"},{"text":" run; display math renders as a full-width block view. In the TextKit 2 path used by ","type":"text"},{"type":"codeVoice","code":"MarkdownView"},{"text":", display math is rasterised as a device-scale image attachment so it renders crisply inside the continuous text view.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To enable math typesetting, add "},{"code":"SwiftMarkdownViewLaTeX","type":"codeVoice"},{"type":"text","text":" to your target’s dependencies and inject the renderer into the view hierarchy:"}]},{"type":"codeListing","syntax":"swift","code":["import SwiftMarkdownView","import SwiftMarkdownViewLaTeX","","MarkdownView(\"\"\"","The quadratic formula: $ax^2 + bx + c = 0$","","$$x = \\\\frac{-b \\\\pm \\\\sqrt{b^2 - 4ac}}{2a}$$","\"\"\")",".mathRenderer(LaTeXMathRenderer())"]},{"type":"paragraph","inlineContent":[{"text":"The renderer’s visual style — font family, font sizes, and text colour — derives from the ","type":"text"},{"code":"swift-design-system","type":"codeVoice"},{"text":" theme in the SwiftUI environment. Pass a custom ","type":"text"},{"code":"MathStyle","type":"codeVoice"},{"text":" to the initialiser when you need to override the defaults.","type":"text"}]}],"kind":"content"}],"sections":[],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftmarkdownviewlatex"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftMarkdownViewLaTeX\/documentation\/SwiftMarkdownViewLaTeX"},"hierarchy":{"paths":[[]]},"topicSections":[{"title":"Math Renderer","identifiers":["doc:\/\/SwiftMarkdownViewLaTeX\/documentation\/SwiftMarkdownViewLaTeX\/LaTeXMathRenderer"],"anchor":"Math-Renderer"}],"abstract":[{"type":"text","text":"LaTeX math typesetting for "},{"type":"codeVoice","code":"SwiftMarkdownView"},{"type":"text","text":", powered by SwiftLaTeXView."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"role":"collection","roleHeading":"Framework","title":"SwiftMarkdownViewLaTeX","externalID":"SwiftMarkdownViewLaTeX","color":{"standardColorIdentifier":"purple"},"symbolKind":"module","modules":[{"name":"SwiftMarkdownViewLaTeX"}]},"references":{"doc://SwiftMarkdownViewLaTeX/documentation/SwiftMarkdownViewLaTeX/LaTeXMathRenderer":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LaTeXMathRenderer","kind":"identifier"}],"role":"symbol","title":"LaTeXMathRenderer","url":"\/documentation\/swiftmarkdownviewlatex\/latexmathrenderer","kind":"symbol","abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"MathRenderer"},{"type":"text","text":" that typesets math via SwiftLaTeXView."}],"identifier":"doc:\/\/SwiftMarkdownViewLaTeX\/documentation\/SwiftMarkdownViewLaTeX\/LaTeXMathRenderer","type":"topic","navigatorTitle":[{"text":"LaTeXMathRenderer","kind":"identifier"}]},"doc://SwiftMarkdownViewLaTeX/documentation/SwiftMarkdownViewLaTeX":{"role":"collection","url":"\/documentation\/swiftmarkdownviewlatex","title":"SwiftMarkdownViewLaTeX","kind":"symbol","abstract":[{"type":"text","text":"LaTeX math typesetting for "},{"code":"SwiftMarkdownView","type":"codeVoice"},{"type":"text","text":", powered by SwiftLaTeXView."}],"identifier":"doc:\/\/SwiftMarkdownViewLaTeX\/documentation\/SwiftMarkdownViewLaTeX","type":"topic"}}}